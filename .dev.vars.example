# Cloudflare Access SaaS application (OIDC) — for the MCP OAuth login flow
ACCESS_CLIENT_ID=your-saas-app-client-id
ACCESS_CLIENT_SECRET=your-saas-app-client-secret
ACCESS_TOKEN_URL=https://your-team.cloudflareaccess.com/cdn-cgi/access/sso/oidc/your-app-id/token
ACCESS_AUTHORIZATION_URL=https://your-team.cloudflareaccess.com/cdn-cgi/access/sso/oidc/your-app-id/authorize

# Cloudflare Access audience tag(s) accepted for JWT verification.
# Comma-separate when using both self-hosted and SaaS Access apps.
ACCESS_AUD_TAG=your-self-hosted-aud-tag,your-saas-aud-tag

# JWKS endpoint(s) used to verify JWT signatures.
# Comma-separate team-level and SaaS-app-specific JWKS URLs when needed.
ACCESS_JWKS_URL=https://your-team.cloudflareaccess.com/cdn-cgi/access/certs,https://your-team.cloudflareaccess.com/cdn-cgi/access/sso/oidc/your-saas-app-id/jwks

# Optional issuer allowlist. If omitted, issuer defaults to JWKS URL origins.
# ACCESS_ISSUER=https://your-team.cloudflareaccess.com

# Random key for encrypting OAuth cookies — generate with: openssl rand -hex 32
COOKIE_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
