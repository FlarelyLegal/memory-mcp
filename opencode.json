{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "*": "deny",
      "git *": "allow",
      "npm run *": "allow",
      "npm test*": "allow",
      "npx wrangler *": "allow",
      "jj *": "deny"
    },
