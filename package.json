{
  "name": "memory-graph-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "db:init": "wrangler d1 execute memory-graph-mcp-db --remote --file=schemas/schema.sql",
    "db:init:local": "wrangler d1 execute memory-graph-mcp-db --local --file=schemas/schema.sql",
    "changelog": "git-cliff -o CHANGELOG.md",
    "changelog:check": "git-cliff --unreleased"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.2.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "agents": "^0.6.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "agents": {
      "@modelcontextprotocol/sdk": "$@modelcontextprotocol/sdk"
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "git-cliff": "^2.12.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1",
    "wrangler": "^4.0.0"
  }
}
